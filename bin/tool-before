#!/usr/bin/env bash
_RECORD_CHECK=tool-before
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

TOOL_A="$1"
TOOL_B="$2"
FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

IDX_A=$(jq -s 'to_entries | map(select(.value.tool == "'"$TOOL_A"'")) | first // empty | .key' "$FILE" 2>/dev/null)
IDX_B=$(jq -s 'to_entries | map(select(.value.tool == "'"$TOOL_B"'")) | first // empty | .key' "$FILE" 2>/dev/null)

if [ -z "$IDX_A" ] || [ "$IDX_A" = "null" ]; then
    record_fail "$TOOL_A never called"
    exit 1
fi

if [ -z "$IDX_B" ] || [ "$IDX_B" = "null" ]; then
    record_fail "$TOOL_B never called"
    exit 1
fi

if [ "$IDX_A" -lt "$IDX_B" ]; then
    record_pass "$TOOL_A (line $((IDX_A + 1))) before $TOOL_B (line $((IDX_B + 1)))"
else
    record_fail "$TOOL_A at line $((IDX_A + 1)) occurred after $TOOL_B at line $((IDX_B + 1))"
    exit 1
fi
