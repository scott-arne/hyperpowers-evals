[
  {
    "name": "jsonl form: read_file + run_shell_command",
    "input": "{\"kind\": \"main\"}\n{\"type\": \"gemini\", \"content\": \"Reading file\", \"toolCalls\": [{\"id\": \"read_file_1\", \"name\": \"read_file\", \"args\": {\"file_path\": \"GEMINI.md\"}, \"status\": \"success\"}]}\n{\"type\": \"gemini\", \"content\": \"Running command\", \"toolCalls\": [{\"id\": \"shell_1\", \"name\": \"run_shell_command\", \"args\": {\"command\": \"git status\"}, \"status\": \"success\"}]}",
    "expected": [
      {
        "tool": "Read",
        "args": {
          "file_path": "GEMINI.md"
        },
        "source": "native"
      },
      {
        "tool": "Bash",
        "args": {
          "command": "git status"
        },
        "source": "shell"
      }
    ]
  },
