#!/usr/bin/env bash
# Rebuild coding-agents/claude-home-skeleton/ from a populated source dir.
#
# The skeleton is the dialog-bypass state quorum copies into each per-run
# CLAUDE_CONFIG_DIR so claude boots straight to the prompt without blocking on
# workspace-trust, onboarding, or API-key-approval dialogs.
#
# This script scrubs per-user / per-machine / per-key cruft from the source
# .claude.json, leaving only the universal dialog-bypass flags. The result is
# committed to git — no per-machine rebuild needed.
#
# Source defaults to /tmp/claude-source. To build a fresh source: run
# `CLAUDE_CONFIG_DIR=/tmp/claude-source claude` once on a clean machine, click
# through every dialog (theme picker, API-key picker, etc.), then invoke this
# script with --source /tmp/claude-source.
set -euo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

SOURCE="/tmp/claude-source"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --source) SOURCE="$2"; shift 2 ;;
        -h|--help)
            sed -n '2,14p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DEST="$REPO_ROOT/coding-agents/claude-home-skeleton"

[ -f "$SOURCE/.claude.json" ] || { echo "no .claude.json in $SOURCE" >&2; exit 1; }

rm -rf "$DEST"
mkdir -p "$DEST"

# .claude.json: keep universal dialog-bypass flags; scrub everything that is
# per-user (userID, customApiKeyResponses), per-machine (timestamps, terminal),
# or transient cache (cachedGrowthBookFeatures, etc.).
jq '
    del(.githubRepoPaths)
    | .projects = {}
    | del(.userID)
    | del(.customApiKeyResponses)
    | del(.firstStartTime)
    | del(.numStartups)
    | del(.tipsHistory)
    | del(.seenNotifications)
    | del(.changelogLastFetched)
    | del(.lastReleaseNotesSeen)
    | del(.closedIssuesLastChecked)
    | del(.cachedGrowthBookFeatures)
    | del(.cachedExperimentFeatures)
    | del(.clientDataCache)
    | del(.additionalModelOptionsCache)
    | del(.additionalModelCostsCache)
    | del(.metricsStatusCache)
    | del(.deepLinkTerminal)
    | del(.opus47LaunchSeenCount)
    | del(.oauthAccount)
' "$SOURCE/.claude.json" > "$DEST/.claude.json"

# settings.json (theme + skipDangerousModePermissionPrompt) — copy if present.
[ -f "$SOURCE/settings.json" ] && cp "$SOURCE/settings.json" "$DEST/settings.json"

echo "Wrote $DEST from $SOURCE"
ls -la "$DEST"
