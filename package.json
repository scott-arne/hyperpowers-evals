{
  "name": "quorum",
  "version": "0.1.2",
  "type": "module",
  "bin": {
    "quorum": "./src/cli/index.ts"
  },
  "engines": {
    "bun": ">=1.3.13"
  },
  "scripts": {
    "quorum": "bun run src/cli/index.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "check": "biome ci . && tsc --noEmit && bun test",
    "build": "bun build src/cli/index.ts --compile --outfile dist/quorum"
  },
  "dependencies": {
    "@primeradianthq/obol": "^0.5.0",
    "commander": "^12",
    "yaml": "^2",
    "zod": "^3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2",
    "@types/bun": "latest",
    "typescript": "^5.9"
  }
}
