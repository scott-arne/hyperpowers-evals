#!/usr/bin/env bash
# Verify a specific Skill was invoked before any call of a named tool.
#
# Usage: skill-before-tool <skill-name> <tool-name>
# Example: skill-before-tool superpowers:writing-plans Edit
#
# Semantics (mirrors skill-before-tool-match, but gates on a plain tool
# name instead of a Bash command regex):
#   - If the gated tool never fires, PASS (vacuously — the event we'd
#     have gated on didn't happen).
#   - If the gated tool fires but Skill(name) never appeared earlier, FAIL.
#   - If both appeared and Skill came first, PASS.
_RECORD_CHECK=skill-before-tool
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

SKILL_NAME="$1"
SKILL_DIR="${SKILL_NAME##*:}"
TOOL_NAME="$2"
FILE="${BARF_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

if [ ! -s "$FILE" ]; then
    record_fail "tool-calls file missing or empty"
    exit 1
fi

# First index where the skill was invoked, via the shared predicate so
# this tool counts shell-read SKILL.md files alongside native Skill
# calls — same rule as skill-called (Codex review P2, 2026-05-24).
SKILL_IDX=$(
    jq -L "$(dirname "$0")" -s \
        --arg name "$SKILL_NAME" --arg dir "$SKILL_DIR" \
        'include "_skill_predicate";
         to_entries | map(select(.value | is_skill_invocation($name; $dir)))
         | first | (.key // -1)' \
        "$FILE"
)

TOOL_IDX=$(
    jq -s --arg tool "$TOOL_NAME" \
        'to_entries | map(select(.value.tool == $tool)) | first | (.key // -1)' \
        "$FILE"
)

if [ "$TOOL_IDX" -lt 0 ]; then
    record_pass "no $TOOL_NAME call — assertion is vacuous"
    exit 0
fi

if [ "$SKILL_IDX" -lt 0 ]; then
    record_fail "$TOOL_NAME fired at line $((TOOL_IDX + 1)) but Skill($SKILL_NAME) never fired"
    exit 1
fi

if [ "$SKILL_IDX" -lt "$TOOL_IDX" ]; then
    record_pass "Skill($SKILL_NAME) at line $((SKILL_IDX + 1)) before $TOOL_NAME at line $((TOOL_IDX + 1))"
else
    record_fail "Skill($SKILL_NAME) at line $((SKILL_IDX + 1)) fired after $TOOL_NAME at line $((TOOL_IDX + 1))"
    exit 1
fi
