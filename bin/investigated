#!/usr/bin/env bash
_RECORD_CHECK=investigated
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

# Passes if the agent investigated the code by a targeted read or search,
# by any reachable means:
#   - Claude: a native Read or Grep tool call, OR
#   - Codex (no native Read/Grep primitive): a Bash call running `grep`
#     or `rg`.
#
# Replaces the inline `jq 'any(.tool=="Read" or .tool=="Grep")'` predicate
# that cost-tool-result-bloat used to carry. That predicate was Claude-only
# and false-failed every Codex run: Codex greps via the shell, so all its
# tool calls normalize to "Bash" and zero "Read"/"Grep" ever appear.
#
# Mirrors the worktree-created OR-pattern (native primitive OR shell
# equivalent). Like that check, this only proves investigation *happened* —
# it is a proxy, not a measure of read-bloat. See the scenario story for the
# qualitative criterion.

FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

NATIVE=$(jq -s '[.[] | select(.tool == "Read" or .tool == "Grep")] | length' "$FILE" 2>/dev/null || echo 0)
# Word-boundary match so `grep`/`rg` as a command word counts, but
# substrings (e.g. a filename containing "grep") do not. POSIX classes —
# Oniguruma (jq's engine) supports them; worktree-created relies on the same.
SHELL_=$(jq -s '[.[] | select(.tool == "Bash") | select(.args.command | test("(^|[^[:alnum:]_])(grep|rg)([^[:alnum:]_]|$)"))] | length' "$FILE" 2>/dev/null || echo 0)

if [ "$NATIVE" -gt 0 ]; then
    record_pass "native Read/Grep called $NATIVE time(s)"
elif [ "$SHELL_" -gt 0 ]; then
    record_pass "grep/rg invoked via Bash $SHELL_ time(s)"
else
    record_fail "no investigation observed (neither native Read/Grep nor shell grep/rg)"
    exit 1
fi
