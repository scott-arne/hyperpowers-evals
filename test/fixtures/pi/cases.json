  {
    "name": "assistant tool calls (read/bash/subagent)",
    "input": "{\"type\": \"session\", \"cwd\": \"/tmp/project\"}\n{\"type\": \"message\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"text\", \"text\": \"I will inspect this.\"}, {\"type\": \"toolCall\", \"name\": \"read\", \"arguments\": {\"path\": \"README.md\"}}, {\"type\": \"toolCall\", \"name\": \"bash\", \"arguments\": {\"command\": \"git status\"}}, {\"type\": \"toolCall\", \"name\": \"subagent\", \"arguments\": {\"agent\": \"reviewer\"}}]}}",
    "expected": [
      {
        "tool": "Read",
        "args": {
          "path": "README.md"
        },
        "source": "native"
      },
      {
        "tool": "Bash",
        "args": {
          "command": "git status"
        },
        "source": "shell"
      },
      {
        "tool": "Agent",
        "args": {
          "agent": "reviewer"
        },
        "source": "native"
      }
    ]
  },
  {
    "name": "subagent execution vs management calls",
    "input": "{\"type\": \"session\", \"cwd\": \"/tmp/project\"}\n{\"type\": \"message\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"toolCall\", \"name\": \"subagent\", \"arguments\": {\"agent\": \"reviewer\", \"task\": \"review the diff\"}}]}}\n{\"type\": \"message\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"toolCall\", \"name\": \"subagent\", \"arguments\": {\"chain\": [{\"agent\": \"scout\"}, {\"agent\": \"planner\"}]}}]}}\n{\"type\": \"message\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"toolCall\", \"name\": \"subagent\", \"arguments\": {\"tasks\": [{\"agent\": \"reviewer\", \"count\": 3}], \"concurrency\": 3}}]}}\n{\"type\": \"message\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"toolCall\", \"name\": \"subagent\", \"arguments\": {\"action\": \"list\"}}]}}\n{\"type\": \"message\", \"message\": {\"role\": \"assistant\", \"content\": [{\"type\": \"toolCall\", \"name\": \"subagent\", \"arguments\": {\"action\": \"status\", \"id\": \"run-1\"}}]}}",
    "expected": [
      {
        "tool": "Agent",
        "args": {
          "agent": "reviewer",
          "task": "review the diff"
        },
        "source": "native"
      },
      {
        "tool": "Agent",
        "args": {
          "chain": [
            {
              "agent": "scout"
            },
            {
              "agent": "planner"
            }
          ]
        },
        "source": "native"
      },
      {
        "tool": "Agent",
        "args": {
          "tasks": [
            {
              "agent": "reviewer",
              "count": 3
            }
          ],
          "concurrency": 3
        },
        "source": "native"
      },
      {
        "tool": "subagent",
        "args": {
          "action": "list"
        },
        "source": "native"
      },
      {
        "tool": "subagent",
        "args": {
          "action": "status",
          "id": "run-1"
        },
        "source": "native"
      }
    ]
  },
  {
