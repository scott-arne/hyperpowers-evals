#!/usr/bin/env bash
# Rebuild fixtures/skeleton-claude-home/ from a populated source dir.
#
# The skeleton is the dialog-bypass state Drill copies into each per-run
# CLAUDE_CONFIG_DIR so claude boots straight to the prompt without blocking
# on workspace-trust, onboarding, or API-key-approval dialogs. It contains
# user-specific identifiers (API-key hash, userID) so it is gitignored —
# every machine rebuilds its own.
#
# Source defaults to /tmp/claude-pro-temp. To build a fresh source: run
# `CLAUDE_CONFIG_DIR=/tmp/claude-source claude` once, click through every
# dialog with your real ANTHROPIC_API_KEY active, then invoke this script
# with --source /tmp/claude-source.
set -euo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

SOURCE="/tmp/claude-pro-temp"
while [[ $# -gt 0 ]]; do
    case "$1" in
        --source) SOURCE="$2"; shift 2 ;;
        -h|--help)
            sed -n '2,12p' "$0" | sed 's/^# \{0,1\}//'
            exit 0
            ;;
        *) echo "unknown arg: $1" >&2; exit 2 ;;
    esac
done

REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
DEST="$REPO_ROOT/fixtures/skeleton-claude-home"

[ -f "$SOURCE/.claude.json" ] || { echo "no .claude.json in $SOURCE" >&2; exit 1; }

rm -rf "$DEST"
mkdir -p "$DEST"

# .claude.json: drop the per-project entries (Drill injects its own at runtime)
# and the user's githubRepoPaths history. Keep onboarding flags, customApiKey
# response hashes, migration markers, etc.
jq 'del(.githubRepoPaths) | .projects = {}' "$SOURCE/.claude.json" > "$DEST/.claude.json"

# settings.json (theme + skipDangerousModePermissionPrompt) — copy if present.
[ -f "$SOURCE/settings.json" ] && cp "$SOURCE/settings.json" "$DEST/settings.json"

echo "Wrote $DEST from $SOURCE"
ls -la "$DEST"
