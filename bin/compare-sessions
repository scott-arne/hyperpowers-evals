#!/usr/bin/env python3
"""Side-by-side comparison of two claude session JSONLs.

Usage:
  bin/compare-sessions <left.jsonl> <right.jsonl> [--full]

Pulls out the bits most likely to explain divergent agent behavior:
  - cwd            (from the first system event's content)
  - user prompts   (real user messages, not tool_results)
  - tool calls     (in order, with brief input summary)
  - skills         (Skill tool invocations, called out separately)
  - assistant text (any final user-visible explanations)

By default, long values are truncated. Pass --full to expand.
"""
from __future__ import annotations

import json
import re
import shutil
import sys
from pathlib import Path

TRUNC = 240
SEP = " │ "


def parse_jsonl(path: Path) -> list[dict]:
    events = []
    for line in path.read_text().splitlines():
        if not line.strip():
            continue
        try:
            events.append(json.loads(line))
        except json.JSONDecodeError:
            pass
    return events


def extract_cwd(events: list[dict]) -> str:
    # Claude Code writes cwd into top-level "cwd" on most events, and also
    # mentions it in the system prompt content. Top-level is reliable.
    for ev in events:
        if cwd := ev.get("cwd"):
            return str(cwd)
    return "(not found)"


_CLI_NOISE_RE = re.compile(
    r"<local-command-(?:caveat|stdout|stderr)>|<command-(?:name|message|args)>"
)


def extract_user_prompts(events: list[dict]) -> list[str]:
    """Real user messages — exclude tool_results and Claude Code CLI noise.

    Claude Code wraps slash-commands, `/exit` confirmations, command stdout
    captures, etc. in <local-command-…> / <command-…> tags as user-role
    messages. They aren't anything the actor/QA agent actually typed at
    the prompt; filter them so the column shows the real conversation.
    """
    out = []
    for ev in events:
        if ev.get("type") != "user":
            continue
        content = ev.get("message", {}).get("content")
        if isinstance(content, str) and not _CLI_NOISE_RE.search(content):
            out.append(content)
        # If content is a list, it's tool_results — skip.
    return out


def extract_assistant_text(events: list[dict]) -> list[str]:
    """Visible assistant text blocks (not thinking, not tool_use)."""
    out = []
    for ev in events:
        if ev.get("type") != "assistant":
            continue
        content = ev.get("message", {}).get("content")
        if not isinstance(content, list):
            continue
        for block in content:
            if isinstance(block, dict) and block.get("type") == "text":
                text = block.get("text", "").strip()
                if text:
                    out.append(text)
    return out


def extract_tool_calls(events: list[dict]) -> list[tuple[str, dict]]:
    """List of (tool_name, input_dict) in order."""
    out = []
    for ev in events:
        if ev.get("type") != "assistant":
            continue
        content = ev.get("message", {}).get("content")
        if not isinstance(content, list):
            continue
        for block in content:
            if isinstance(block, dict) and block.get("type") == "tool_use":
                out.append((block.get("name", "?"), block.get("input", {})))
    return out


def extract_skills(tool_calls: list[tuple[str, dict]]) -> list[tuple[int, str]]:
    """(1-based call index, skill name) for each Skill invocation."""
    return [
        (i + 1, inp.get("skill", inp.get("name", "?")))
        for i, (name, inp) in enumerate(tool_calls)
        if name == "Skill"
    ]


def truncate(s: str, n: int, full: bool) -> str:
    s = re.sub(r"\s+", " ", s.strip())
    if full or len(s) <= n:
        return s
    return s[: n - 1] + "…"


def brief_input(name: str, inp: dict, full: bool) -> str:
    """One-line summary of a tool call's most salient inputs."""
    if not inp:
        return ""
    # Pick the most-telling key per tool, falling back to compact json.
    key_priority = {
        "Bash": "command",
        "Read": "file_path",
        "Edit": "file_path",
        "Write": "file_path",
        "Skill": "skill",
        "Agent": "description",
        "Grep": "pattern",
        "Glob": "pattern",
        "TaskCreate": "content",
        "TaskUpdate": "content",
    }
    if (k := key_priority.get(name)) and k in inp:
        return truncate(f"{k}={inp[k]}", TRUNC, full)
    return truncate(json.dumps(inp), TRUNC, full)


def lay_out_side_by_side(left: list[str], right: list[str], width: int) -> str:
    """Print two lists of lines as two columns of `width` chars each."""
    h = max(len(left), len(right), 1)
    out = []
    for i in range(h):
        l = (left[i] if i < len(left) else "").ljust(width)
        r = right[i] if i < len(right) else ""
        out.append(f"{l[:width]}{SEP}{r}")
    return "\n".join(out)


def section(title: str, total_width: int) -> str:
    inner = f"  {title}  "
    pad = max(0, total_width - len(inner))
    lpad = pad // 2
    rpad = pad - lpad
    return "\n" + ("─" * lpad) + inner + ("─" * rpad) + "\n"


def wrap_to_lines(text: str, width: int) -> list[str]:
    """Wrap a single string into a list of lines of given width."""
    text = text.rstrip()
    if not text:
        return [""]
    lines = []
    for paragraph in text.split("\n"):
        if not paragraph:
            lines.append("")
            continue
        while paragraph:
            lines.append(paragraph[:width])
            paragraph = paragraph[width:]
    return lines


def render(events: list[dict], full: bool, pane_width: int) -> dict[str, list[str]]:
    """Return per-section lines for one side."""
    prompts = extract_user_prompts(events)
    tools = extract_tool_calls(events)
    skills = extract_skills(tools)
    assistant = extract_assistant_text(events)

    prompt_lines = []
    for i, p in enumerate(prompts, 1):
        prompt_lines.extend(wrap_to_lines(f"[{i}] {truncate(p, TRUNC, full)}", pane_width))
        prompt_lines.append("")

    tool_lines = [f"(N={len(tools)})", ""]
    for i, (name, inp) in enumerate(tools, 1):
        tool_lines.extend(
            wrap_to_lines(f"{i:>3}. {name:<10} {brief_input(name, inp, full)}", pane_width)
        )

    skill_lines = (
        [f"@call#{idx}: {name}" for idx, name in skills] if skills else ["(none invoked)"]
    )

    assist_lines = []
    for i, t in enumerate(assistant, 1):
        assist_lines.extend(wrap_to_lines(f"[{i}] {truncate(t, TRUNC, full)}", pane_width))
        assist_lines.append("")

    return {
        "prompts": prompt_lines,
        "tools": tool_lines,
        "skills": skill_lines,
        "assistant": assist_lines,
    }


def main() -> int:
    args = [a for a in sys.argv[1:] if a != "--full"]
    full = "--full" in sys.argv[1:]
    if len(args) != 2:
        print(__doc__, file=sys.stderr)
        return 2
    left_path, right_path = Path(args[0]), Path(args[1])
    for p in (left_path, right_path):
        if not p.exists():
            print(f"not found: {p}", file=sys.stderr)
            return 1

    cols = shutil.get_terminal_size((140, 24)).columns
    pane_width = max(40, (cols - len(SEP)) // 2)
    total_width = pane_width * 2 + len(SEP)

    left_events = parse_jsonl(left_path)
    right_events = parse_jsonl(right_path)

    print(f"left:  {left_path}")
    print(f"right: {right_path}")
    print(f"events: left={len(left_events)} right={len(right_events)}")

    print(section("CWD", total_width))
    print(lay_out_side_by_side(
        [extract_cwd(left_events)], [extract_cwd(right_events)], pane_width
    ))

    left_r = render(left_events, full, pane_width)
    right_r = render(right_events, full, pane_width)

    for title, key in [
        ("USER PROMPTS", "prompts"),
        ("TOOL CALLS", "tools"),
        ("SKILLS INVOKED", "skills"),
        ("ASSISTANT TEXT", "assistant"),
    ]:
        print(section(title, total_width))
        print(lay_out_side_by_side(left_r[key], right_r[key], pane_width))

    return 0


if __name__ == "__main__":
    sys.exit(main())
