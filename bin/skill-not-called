#!/usr/bin/env bash
# Verify a specific superpowers Skill was NOT invoked.
#
# Usage: skill-not-called <skill-name>
# Example: skill-not-called superpowers:brainstorming
#
# Inverse of skill-called — passes when the skill never fired. Used by
# cost scenarios that measure skill over-triggering. Detection mirrors
# skill-called: a Skill tool call OR a shell command reading the skill's
# SKILL.md both count as "called".
set -euo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

SKILL_NAME="$1"
SKILL_DIR="${SKILL_NAME##*:}"
FILE="tool_calls.jsonl"

COUNT=$(
    jq -s --arg name "$SKILL_NAME" --arg dir "$SKILL_DIR" \
        '[.[] | select(
            (.tool == "Skill" and (.args.skill // "") == $name)
            or (
                ((.tool // "") | test("^(Bash|Shell|LocalShellCall)$"))
                and (
                    ((.args.command // .args.cmd // "") | test(
                        "(^|[[:space:]'\''\"/])skills/(superpowers/)?" + $dir + "/SKILL[.]md([[:space:]'\''\";]|$)"
                    ))
                )
            )
        )] | length' \
        "$FILE" 2>/dev/null || echo 0
)

if [ "$COUNT" -eq 0 ]; then
    echo "PASS: Skill($SKILL_NAME) never called"
    exit 0
else
    echo "FAIL: Skill($SKILL_NAME) called $COUNT time(s) (expected 0)"
    exit 1
fi
