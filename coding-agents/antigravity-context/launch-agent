#!/usr/bin/env bash
# quorum-generated launcher for Google Antigravity (the agent under test).
#
# The cd, throwaway-$HOME pin, ANTIGRAVITY_CONFIG_DIR, explicit --gemini_dir,
# auto-update disable, and dangerous-mode flag are baked in here so the QA agent
# starts agy from the prepared workdir with one command. quorum substitutes the
# $... values below at runtime; the installed copy contains literal absolute
# paths. When the real workdir path contains a hidden component, $QUORUM_AGENT_CWD
# may be a visible symlink to that workdir so Antigravity accepts it as a
# workspace.
#
# Throwaway $HOME: $QUORUM_HOME_ENV pins HOME (+XDG +TMPDIR) to the per-run home
# (= $QUORUM_AGENT_HOME) so agy cannot read/write the operator's real ~/.gemini,
# ~/.config, etc. With antigravity.yaml's home_config_subdir ".", the config dir
# IS that home, so $ANTIGRAVITY_CONFIG_DIR == $QUORUM_AGENT_HOME and
# $ANTIGRAVITY_CONFIG_DIR/.gemini == $QUORUM_AGENT_HOME/.gemini — the single dir
# where provisioning seeds the plugin, settings, AND the C1 OAuth creds.
#
# CRITICAL (C1): agy reads its live, rotating OAuth token from
# $HOME/.gemini/oauth_creds.json at RUNTIME, NOT from --gemini_dir. Because HOME
# is now the throwaway home, that read would miss the operator's creds unless
# provisioning copied them in — which it does (see seedAgyOauthCredentials in
# src/agents/antigravity.ts). The keyring entry is per-login-user, not
# home-relative, so it survives the throwaway HOME.
#
# --gemini_dir stays EXPLICIT: it relocates agy's STATE tree (config, plugins,
# antigravity-cli/{settings,brain}). It already resolves to the throwaway
# home's .gemini (the same dir HOME would default to), so it is belt-and-braces,
# not load-bearing for relocation here — but keep it pinned to a known path so a
# future HOME-default change can't silently move the state tree. (FLAGGED: a
# live agy smoke is required before dropping it, even though empirically agy
# defaults --gemini_dir to $HOME/.gemini when omitted.)
#
# Equivalent manual command (for debugging):
#   cd "$QUORUM_AGENT_CWD" && HOME="$QUORUM_AGENT_HOME" ANTIGRAVITY_CONFIG_DIR="$ANTIGRAVITY_CONFIG_DIR" AGY_CLI_DISABLE_AUTO_UPDATE=true agy --gemini_dir="$ANTIGRAVITY_CONFIG_DIR/.gemini" --add-dir="$QUORUM_AGENT_CWD" --dangerously-skip-permissions --log-file "$ANTIGRAVITY_CONFIG_DIR/agy.log"
set -euo pipefail
cd "$QUORUM_AGENT_CWD" || { echo "launch-agent: cannot cd to $QUORUM_AGENT_CWD" >&2; exit 1; }
exec env \
  $QUORUM_HOME_ENV \
  ANTIGRAVITY_CONFIG_DIR="$ANTIGRAVITY_CONFIG_DIR" \
  AGY_CLI_DISABLE_AUTO_UPDATE=true \
  agy \
    --gemini_dir="$ANTIGRAVITY_CONFIG_DIR/.gemini" \
    --add-dir="$QUORUM_AGENT_CWD" \
    --dangerously-skip-permissions \
    --log-file "$ANTIGRAVITY_CONFIG_DIR/agy.log" \
    "$@"
