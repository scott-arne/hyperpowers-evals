#!/usr/bin/env bash
# Verify a specific superpowers Skill was invoked at least once.
#
# Usage: skill-called <skill-name>
# Example: skill-called superpowers:systematic-debugging
#
# Wraps the common case of `tool-arg-match Skill '.skill == "<name>"'` so
# scenario YAML doesn't have to embed jq quoting.
_RECORD_CHECK=skill-called
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

SKILL_NAME="$1"
SKILL_DIR="${SKILL_NAME##*:}"
FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

if [ ! -s "$FILE" ]; then
    record_fail "tool-calls file missing or empty"
    exit 1
fi

# Detection uses the shared `is_skill_invocation` predicate (see
# quorum/bin/_skill_predicate.jq) so this and the three sibling skill-*
# tools recognize the same set of invocation patterns.
COUNT=$(
    jq -L "$(dirname "$0")" -s \
        --arg name "$SKILL_NAME" --arg dir "$SKILL_DIR" \
        'include "_skill_predicate";
         [.[] | select(is_skill_invocation($name; $dir))] | length' \
        "$FILE"
)

if [ "$COUNT" -gt 0 ]; then
    record_pass "Skill($SKILL_NAME) called $COUNT time(s)"
else
    record_fail "Skill($SKILL_NAME) never called"
    exit 1
fi
