#!/usr/bin/env bash
# quorum-generated launcher for Pi (the agent under test).
#
# quorum substitutes the $... values below at runtime, so the installed copy
# contains literal absolute paths. The cd, auth env file, model, extension path,
# and tool allowlist are baked in so the QA agent launches Pi with one command
# and cannot accidentally start from the scratch directory.
#
# PI_CODING_AGENT_DIR collapse: this launcher sets HOME (via $QUORUM_HOME_ENV)
# but NOT PI_CODING_AGENT_DIR, and passes NO --session-dir. pi defaults its
# config dir to $HOME/.pi/agent and its session dir to <config>/sessions, which
# is exactly where the runner seeds the per-run config (pi.yaml:
# home_config_subdir ".pi/agent") — so pi finds its config and writes sessions
# via the isolated $HOME with no config-dir or session-dir flag.
set -euo pipefail

cd "$QUORUM_AGENT_CWD" || {
  echo "launch-agent: cannot cd to $QUORUM_AGENT_CWD" >&2
  exit 1
}

set -a
. "$PI_ENV_FILE"
set +a

# pi-subagents provides the `subagent` delegation tool. It is a host
# prerequisite like pi itself: npm install -g pi-subagents. --no-extensions
# disables ambient discovery, so the package is loaded explicitly by path.
# PI_SUBAGENTS_PKG is resolved here at launch, not substituted by quorum.
PI_SUBAGENTS_PKG="$(npm root -g)/pi-subagents"
if [ ! -d "$PI_SUBAGENTS_PKG" ]; then
  echo "launch-agent: pi-subagents not found at $PI_SUBAGENTS_PKG; run: npm install -g pi-subagents" >&2
  exit 1
fi

exec env \
  $QUORUM_HOME_ENV \
  PI_OFFLINE=1 \
  PI_TELEMETRY=0 \
  pi \
    --provider "$PI_PROVIDER" \
    --model "$PI_MODEL" \
    --no-extensions \
    --extension "$SUPERPOWERS_ROOT" \
    --extension "$PI_SUBAGENTS_PKG" \
    --no-skills \
    --skill "$SUPERPOWERS_ROOT/skills" \
    --no-context-files \
    --tools read,bash,edit,write,grep,find,ls,subagent \
    "$@"
