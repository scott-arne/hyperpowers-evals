#!/usr/bin/env bash
# quorum-generated launcher for Kimi Code (the agent under test).
set -euo pipefail

cleanup_kimi_env() {
  rm -f "$KIMI_ENV_FILE"
}
trap cleanup_kimi_env EXIT HUP INT TERM

cd "$QUORUM_AGENT_CWD" || {
  echo "launch-agent: cannot cd to $QUORUM_AGENT_CWD" >&2
  exit 1
}

set -a
. "$KIMI_ENV_FILE"
set +a
cleanup_kimi_env
trap - EXIT HUP INT TERM
unset KIMI_ENV_FILE
unset -f cleanup_kimi_env

exec kimi --yolo "$@"
