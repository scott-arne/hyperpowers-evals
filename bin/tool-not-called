#!/usr/bin/env bash
_RECORD_CHECK=tool-not-called
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

TOOL="$1"
FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

COUNT=$(jq -s "[.[] | select(.tool == \"$TOOL\")] | length" "$FILE" 2>/dev/null || echo 0)

if [ "$COUNT" -eq 0 ]; then
    record_pass "$TOOL never called"
else
    record_fail "$TOOL called $COUNT time(s) (expected 0)"
    exit 1
fi
