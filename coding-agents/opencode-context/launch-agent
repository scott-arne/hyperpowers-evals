#!/usr/bin/env bash
# quorum-generated launcher for OpenCode (the agent under test).
#
# The cd, isolated HOME/XDG directories, OPENCODE_CONFIG_DIR, and dangerous
# permission flag are baked in here so the QA agent launches OpenCode from the
# prepared workdir with one command. quorum substitutes the $... values below
# at runtime; the installed copy contains literal absolute paths.
#
# HOME/XDG/TMPDIR come from the QUORUM_HOME_ENV token (the single per-run
# throwaway-HOME fragment, rooted at runHomeDir = the QUORUM_AGENT_HOME token).
# opencode keys its session DB off XDG_DATA_HOME, so pinning HOME here puts the
# session store under the same home the capture subprocess (opencodeEnv) uses.
# OPENCODE_CONFIG_DIR mirrors opencodeEnv: <home>/.config/opencode.
set -euo pipefail
cd "$QUORUM_AGENT_CWD" || { echo "launch-agent: cannot cd to $QUORUM_AGENT_CWD" >&2; exit 1; }

env_args=(
  "PATH=${PATH:-/usr/bin:/bin:/usr/sbin:/sbin}"
  "TERM=${TERM:-xterm-256color}"
  "LANG=${LANG:-C.UTF-8}"
)
for name in \
  OPENAI_API_KEY ANTHROPIC_API_KEY OPENROUTER_API_KEY \
  GEMINI_API_KEY GOOGLE_API_KEY \
  AWS_PROFILE AWS_REGION AWS_DEFAULT_REGION \
  AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_SESSION_TOKEN; do
  if [[ -n "${!name-}" ]]; then
    env_args+=("$name=${!name}")
  fi
done

exec env -i \
  "${env_args[@]}" \
  $QUORUM_HOME_ENV \
  OPENCODE_CONFIG_DIR="$QUORUM_AGENT_HOME/.config/opencode" \
  opencode run -i --dangerously-skip-permissions "$@"
