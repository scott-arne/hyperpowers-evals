#!/usr/bin/env bash
_RECORD_CHECK=worktree-created
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

# Passes if the agent created a worktree by any reachable means:
#   - Claude: a native EnterWorktree tool call, OR
#   - Codex (no native worktree primitive): a Bash call whose command
#     contains `git worktree add`.
# The previous shape (`tool-called EnterWorktree`) was Claude-only and
# false-failed every Codex run regardless of whether the worktree was
# actually created.

FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

NATIVE=$(jq -s '[.[] | select(.tool == "EnterWorktree")] | length' "$FILE" 2>/dev/null || echo 0)
SHELL_=$(jq -s '[.[] | select(.tool == "Bash") | select(.args.command | test("git[[:space:]]+worktree[[:space:]]+add"))] | length' "$FILE" 2>/dev/null || echo 0)

if [ "$NATIVE" -gt 0 ]; then
    record_pass "EnterWorktree called $NATIVE time(s)"
elif [ "$SHELL_" -gt 0 ]; then
    record_pass "git worktree add invoked via Bash $SHELL_ time(s)"
else
    record_fail "no worktree creation observed (neither EnterWorktree nor 'git worktree add')"
    exit 1
fi
