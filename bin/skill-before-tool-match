#!/usr/bin/env bash
# Verify a specific Skill was invoked before any Bash call whose command matches a regex.
#
# Usage: skill-before-tool-match <skill-name> <bash-command-regex>
# Example: skill-before-tool-match superpowers:verification-before-completion 'git[[:space:]]+commit'
#
# Semantics:
#   - If no Bash call matches the regex, PASS (vacuously — the gated event never occurred).
#   - If Bash matches but Skill with that name never appeared earlier, FAIL.
#   - If both appeared and Skill came first, PASS.
#   - If Skill never appeared but Bash matched, FAIL.
_RECORD_CHECK=skill-before-tool-match
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

SKILL_NAME="$1"
SKILL_DIR="${SKILL_NAME##*:}"
BASH_REGEX="$2"
FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

if [ ! -s "$FILE" ]; then
    record_fail "tool-calls file missing or empty"
    exit 1
fi

# First index where the skill was invoked, via the shared predicate so
# this tool counts shell-read SKILL.md files alongside native Skill
# calls (Codex review P2, 2026-05-24).
SKILL_IDX=$(
    jq -L "$(dirname "$0")" -s \
        --arg name "$SKILL_NAME" --arg dir "$SKILL_DIR" \
        'include "_skill_predicate";
         to_entries | map(select(.value | is_skill_invocation($name; $dir)))
         | first | (.key // -1)' \
        "$FILE"
)

# First index where Bash(command =~ BASH_REGEX) appears.
BASH_IDX=$(
    jq -s --arg re "$BASH_REGEX" \
        'to_entries | map(select(.value.tool == "Bash" and ((.value.args.command // "") | test($re)))) | first | (.key // -1)' \
        "$FILE"
)

if [ "$BASH_IDX" -lt 0 ]; then
    record_pass "no Bash call matched /$BASH_REGEX/ — assertion is vacuous"
    exit 0
fi

if [ "$SKILL_IDX" -lt 0 ]; then
    record_fail "Bash /$BASH_REGEX/ fired at line $((BASH_IDX + 1)) but Skill($SKILL_NAME) never fired"
    exit 1
fi

if [ "$SKILL_IDX" -lt "$BASH_IDX" ]; then
    record_pass "Skill($SKILL_NAME) at line $((SKILL_IDX + 1)) before Bash /$BASH_REGEX/ at line $((BASH_IDX + 1))"
else
    record_fail "Skill($SKILL_NAME) at line $((SKILL_IDX + 1)) fired after Bash /$BASH_REGEX/ at line $((BASH_IDX + 1))"
    exit 1
fi
