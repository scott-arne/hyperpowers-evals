#!/usr/bin/env bash
_RECORD_CHECK=tool-arg-match
_RECORD_ARGS=("$@")
source "$(dirname "$0")/_record"
set -uo pipefail
command -v jq >/dev/null || { echo "jq required"; exit 127; }

TOOL="$1"
FILTER="$2"
FILE="${QUORUM_TOOL_CALLS_PATH:-coding-agent-tool-calls.jsonl}"

MATCHES=$(jq -s "[.[] | select(.tool == \"$TOOL\") | select(.args | $FILTER)] | length" "$FILE" 2>/dev/null || echo 0)

if [ "$MATCHES" -gt 0 ]; then
    record_pass "$TOOL has $MATCHES call(s) matching filter"
else
    record_fail "no $TOOL calls match filter: $FILTER"
    exit 1
fi
